%% neurips_2024.sty  — NeurIPS 2024 / workshop style (replica)
%% Options: [preprint] (default), [final], [nonatbib]

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/06/01 NeurIPS 2024]

% --- Options ------------------------------------------------------------------
\newif\if@preprint \@preprinttrue
\newif\if@final    \@finalfalse
\DeclareOption{preprint}{\@preprinttrue \@finalfalse}
\DeclareOption{final}   {\@preprintfalse\@finaltrue}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax

% --- Required packages --------------------------------------------------------
\RequirePackage{times}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}

% --- Page geometry (NeurIPS standard) -----------------------------------------
\geometry{
  letterpaper,
  top=1in, bottom=1in,
  left=1.25in, right=1.25in,
  headheight=15pt, headsep=10pt, footskip=30pt
}

% --- Paragraph ----------------------------------------------------------------
\setlength{\parindent}{0pt}
\setlength{\parskip}{4.5pt}

% --- Header marker ------------------------------------------------------------
\newcommand{\@neuripsmark}{%
  \if@preprint Preprint. Under review.\else NeurIPS 2024\fi}

% --- Header / footer ----------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[C]{\small\textit{\@neuripsmark}}
\fancyfoot[C]{\small\thepage}
\renewcommand{\headrulewidth}{0pt}
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyhead[C]{\small\textit{\@neuripsmark}}
  \fancyfoot[C]{\small\thepage}
  \renewcommand{\headrulewidth}{0pt}}

% --- Section headings ---------------------------------------------------------
\def\section{\@startsection{section}{1}{\z@}%
  {-12\p@ \@plus-4\p@ \@minus-2\p@}%
  {4\p@ \@plus2\p@ \@minus2\p@}%
  {\large\bfseries\raggedright}}
\def\subsection{\@startsection{subsection}{2}{\z@}%
  {-10\p@ \@plus-2\p@ \@minus-2\p@}%
  {3\p@ \@plus1\p@ \@minus1\p@}%
  {\normalsize\bfseries\raggedright}}
\def\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-8\p@ \@plus-2\p@ \@minus-2\p@}%
  {2\p@}%
  {\normalsize\itshape\raggedright}}
\def\paragraph{\@startsection{paragraph}{4}{\z@}%
  {6\p@ \@plus2\p@ \@minus1\p@}%
  {-1em}%
  {\normalsize\bfseries}}

% --- Title / author -----------------------------------------------------------
% Safe redefinition of \And (may already be defined by article.cls)
\providecommand{\And}{%
  \end{tabular}\hskip 0.75em plus0.5em minus0.25em%
  \begin{tabular}[t]{c}}

\renewcommand{\maketitle}{%
  \par\begingroup
    \renewcommand\thefootnote{\@fnsymbol\c@footnote}%
    \def\@makefnmark{\rlap{\@textsuperscript{\normalfont\@thefnmark}}}%
    \long\def\@makefntext##1{%
      \parindent 1em\noindent
      \hb@xt@1.8em{\hss\@textsuperscript{\normalfont\@thefnmark}}##1}%
    \@maketitle
    \@thanks
  \endgroup
  \setcounter{footnote}{0}%
  \global\let\thanks\relax
  \global\let\maketitle\relax
  \global\let\@maketitle\relax
  \global\let\@thanks\@empty
  \global\let\@author\@empty
  \global\let\@date\@empty
  \global\let\@title\@empty
  \global\let\title\relax
  \global\let\author\relax
  \global\let\date\relax
}

\def\@maketitle{%
  \newpage\null
  \vskip 1.5em%
  \begin{center}%
    {\LARGE\bfseries\@title\par}%
    \vskip 1em%
    {\normalsize\centering\@author\par}%
  \end{center}%
  \par\vskip 1em}

% --- Abstract -----------------------------------------------------------------
\renewenvironment{abstract}{%
  \vspace{-0.5ex}%
  {\centering\large\bfseries Abstract\par}\vspace{0.5ex}%
  \begin{quote}\small
}{%
  \end{quote}\vspace{1ex}%
}

% --- Defer bibliography tweaks until all packages are loaded ------------------
\AtBeginDocument{%
  \@ifpackageloaded{natbib}{%
    \setlength{\bibsep}{2pt plus 1pt}%
  }{}%
}

\endinput
